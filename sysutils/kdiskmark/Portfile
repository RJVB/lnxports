# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4
# Copyright (c) 2026 R.J.V. Bertin

PortSystem          1.0

PortGroup           github 1.1
PortGroup           qt5 1.0
PortGroup           cmake 1.1
PortGroup           locale_select 1.0

description         An open-source CrystalDiskMark clone for Linux
long_description    KDiskMark is an HDD and SSD benchmark tool with a very \
                    friendly graphical user interface. KDiskMark with its \
                    presets and powerful GUI calls Flexible I/O Tester and \
                    handles the output to provide an easy to view and interpret \
                    comprehensive benchmark result. 
maintainers         gmail.com:rjvbertin openmaintainer

github.setup        JonMagon KDiskMark 9a6cd5f950af647043082cb4c0248e6b2a87541e
fetch.type          git
name                kdiskmark
distname            ${name}-git
version             3.2.0.4

depends_build-append \
                    path:share/ECM/cmake/ECMConfig.cmake:kde-extra-cmake-modules

compiler.cxx_standard \
                    2017

patchfiles-append   patch-allow-non-privileged.diff

configure.args-append \
                    -DUSE_QT5=ON \
                    -DUSE_PRIVILEGED_HELPER=OFF

variant asroot description {run the benchmarking helper with root privileges} {
    depends_lib-append \
                    path:lib/pkgconfig/polkit-qt5-1.pc:polkit-qt5
    configure.args-replace \
                    -DUSE_PRIVILEGED_HELPER=OFF \
                    -DUSE_PRIVILEGED_HELPER=ON
}

build.post_args-append -wk

langselect_qm_dir   ${destroot}${prefix}/share/${name}/${name}/translations
langselect_qm_basename ${name}_

destroot.violate_mtree yes
post-destroot {
    # we need to install stuff for the root/system DBus daemon and/or systemd...
    if {[file exists /etc/dbus-1/system.d]} {
        xinstall -m 755 -d ${destroot}/etc/dbus-1/system.d
        xinstall -m 644 ${destroot}${prefix}/share/dbus-1/system.d/dev.jonmagon.kdiskmark.helperinterface.conf \
            ${destroot}/etc/dbus-1/system.d
    }
    if {[variant_isset asroot]} {
        xinstall -m 755 -d ${destroot}/usr/share/dbus-1/system-services/
        xinstall -m 644 ${destroot}${prefix}/share/dbus-1/system-services/dev.jonmagon.kdiskmark.helperinterface.service \
            ${destroot}/usr/share/dbus-1/system-services/
        xinstall -m 755 -d ${destroot}/usr/share/polkit-1/actions/
        ln -s ${prefix}/share/polkit-1/actions/dev.jonmagon.kdiskmark.helper.policy ${destroot}/usr/share/polkit-1/actions/
    } else {
        xinstall -m 755 -d ${destroot}/usr/share/dbus-1/services/
        ln -s ${prefix}/share/dbus-1/services/dev.jonmagon.kdiskmark.helperinterface.service \
            ${destroot}/usr/share/dbus-1/services/
    }
    file rename ${destroot}${prefix}/bin/kdiskmark ${destroot}${prefix}/bin/kdiskmark.bin
    qt5.add_app_wrapper kdiskmark kdiskmark.bin "" ${prefix}/bin
}
