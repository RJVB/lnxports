PortSystem          1.0
PortGroup           locale_select 1.0
PortGroup           LTO 1.0
PortGroup           save_configure_cmd 1.0
PortGroup           github 1.1

name                ddcutil
version             0.0

github.tarball_from archive
platforms           linux
license             GPL-2

maintainers         gmail.com:rjvbertin openmaintainer

categories          sysutils

homepage            http://www.ddcutil.com/

fetch.type          git

patch.pre_args      -Np1

subport ${name} {
    github.setup    rockowitz ddcutil de592627099f840a93bbf99f8993ee5c5809b9b3
    version         2.2.7.172
    distname        ${subport}-git

    description     Control monitor settings using DDC/CI and USB
    long_description \
                    ddcutil is a Linux program for querying and changing monitor settings, \
                    such as brightness, colour levels, and input connector. \
                    Most monitors, other than laptop displays, have a Virtual Control Panel (VCP), \
                    which implements features defined in the Monitor Control Command Set (MCCS). \
                    Typically, ddcutil communicates with the monitor's VCP over an I2C bus, as per \
                    the Display Data Channel/Command Interface Standard (DDC/CI). \
                    Alternatively, some monitors (e.g. Eizo ColorEdge, Apple Cinema) provide a USB \
                    interface to the VCP, as described in the USB Monitor Control Class Specification. \
                    ddcutil can communicate with these monitors over USB instead of I2C.


#     checksums       rmd160  4c8a450d5c99c04c7400a4a6434546ff23fd1c67 \
#                     sha256  7b5cb9824c23974241146f4a696abc65f8e9d1e950198c8dc00e4a5c6a2f41ee
#     #                 size    1062177

    depends_build-append \
                    port:autoconf \
                    port:automake \
                    port:libtool \
                    port:pkgconfig

    depends_lib-append \
                    port:glib2 \
                    port:hwdata \
                    port:i2c-tools \
                    port:libdrm \
                    port:jansson \
                    port:systemd \
                    port:libusb \
                    port:xorg-libX11 \
                    port:xorg-libXrandr \
                    port:dbus \
                    port:acl \
                    port:attr \
                    port:zlib

    patchfiles-append \
                    ddcutil/patch-less-logging.diff

    if {![file exists ${worksrcpath}/config.log]} {
        configure.cmd \
                    ${worksrcpath}/autogen.sh
    }
    pre-configure {
        if {![file exists ${worksrcpath}/config/ltmain.sh]} {
            xinstall -m 644 ${prefix}/share/libtool/build-aux/ltmain.sh ${worksrcpath}/config/
        }
    }

    # this is for doing reproducible builds:
    configure.args-append \
                    --disable-build-timestamp
}

subport ddcui {
    PortGroup       qt5 1.0
    PortGroup       cmake 1.1

    github.setup    rockowitz ddcui f08bc70bb510f04dc143dc9da34228e82543240d
    version         0.6.0.216

    description     Control monitor settings using DDC/CI and USB
    long_description \
                    ddcui is a graphical user interface for ddcutil

    depends_lib-append \
                    port:glib2 \
                    port:ddcutil
    qt5.depends_component \
                    qttools

    patchfiles-append \
                    ddcui/patch-cmakelists.diff

    configure.args-append \
                    -DUSE_QT5=ON \
                    -DUSE_QT6=OFF

    post-destroot {
        file delete -force ${destroot}${prefix}/lib/modules-load.d
    }
}

build.post_args-append -k

