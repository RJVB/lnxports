# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:et:sw=4:ts=4:sts=4

PortSystem 1.0
set LTO_needs_pre_build yes
PortGroup           LTO 1.0
PortGroup           save_configure_cmd 1.0
PortGroup           conflicts_build 1.0
PortGroup           preserve_runtime_libraries 1.0
PortGroup           devport 1.0

name                libsndio
version             1.10.0
categories          audio
license             ISCL
maintainers         gmail.com:rjvbertin
description         Sndio is a small audio and MIDI framework part of the OpenBSD project.
long_description    libsndio provides an lightweight audio & MIDI server and a fully documented \
                    user-space API to access either the server or directly the hardware in \
                    a uniform way.  Sndio is designed to work for desktop applications, \
                    but pays special attention to synchronisation mechanisms and \
                    reliability required by music applications.  Reliability through \
                    simplicity are part of the project goals.
homepage            http://www.sndio.org
platforms           linux
master_sites        ${homepage}
distname            sndio-${version}
checksums           rmd160  6278fdb26c838f717db1123dc912480133577bba \
                    sha256  bebd3bfd01c50c9376cf3e7814b9379bed9e17d0393b5113b7eb7a3d0d038c54
#                    size    162725

##############################
    create_devport port:${name}

    if {${subport} eq "${name}-dev"} {
        # libsndio-dev doesn't care about anything that follows,
        # return here to avoid having to add more subport checks.
        return
    }
##############################

depends_build       port:pkgconfig

configure.args      --precision=24 \
                    --enable-umidi
build.args          "CC=${configure.cc}" \
                    "CPPFLAGS+=\"${configure.cppflags}\"" \
                    "CFLAGS+=\"${configure.cflags}\"" \
                    "LDFLAGS+=\"${configure.ldflags}\""

conflicts_build     libsndio-dev

pre-configure {
    if {[file exists ${prefix}/lib/libsndio.so]} {
        ui_warn "You are upgrading from an earlier version that didn't yet provide port:libsndio-dev.\n\
            The ${prefix}/lib/libsndio.so linker lib has to be removed, which will fail if you are not \
            executing the configure step with root privileges!"
        file delete ${prefix}/lib/libsndio.so
    }
}

configure.save_build_cmd "install"

post-destroot {
    register_devport_standard_content
    create_devport_content_archive
}

pre-install {
    if {![file exists /var/run/sndiod]} {
        system "mkdir -p /var/run/sndiod"
        catch {system "useradd -r -g audio -s /sbin/nologin -d /var/run/sndiod sndiod"}
    }
}

livecheck.type      regex
livecheck.url       ${homepage}
livecheck.regex     "sndio-(\\d+(?:\\.\\d+)*)${extract.suffix}"
