# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           cmake 1.1
PortGroup           github 1.0
PortGroup           LTO 1.0
PortGroup           preserve_runtime_libraries 1.0


if {(${os.platform} eq "linux" && [file exists ${prefix}/lib/libical.so.2])} {
    default_variants-append +preserve_runtime_libraries
}

github.setup        libical libical 3.0.18 v ; revision 1
checksums           rmd160  3169ffbee16545db4b73f0168b8a1845bbb3278c \
                    sha256  72b7dc1a5937533aee5a2baefc990983b66b141dd80d43b51f80aced4aae219c
#                    size    908948
github.tarball_from archive

categories          devel
maintainers         nomaintainer
license             {LGPL-2.1 MPL-2}

description         An implementation of iCalendar protocols and data formats
long_description    {*}${description}

depends_build-append \
                    port:libxml2 \
                    path:bin/perl:perl5 \
                    path:bin/pkg-config:pkgconfig

depends_lib-append  path:lib/pkgconfig/glib-2.0.pc:glib2 \
                    path:lib/pkgconfig/icu-uc.pc:icu

configure.args      -DGOBJECT_INTROSPECTION=OFF \
                    -DICAL_GLIB_VAPI=OFF \
                    -DICAL_BUILD_DOCS=OFF

# C++ compiler is used for C++ bindings
compiler.cxx_standard   2011

# https://github.com/libical/libical/issues/723
use_parallel_build  no

variant vala description {install the GObject Introspection and Vala components} {
    depends_build-append \
                    path:bin/vala:vala
    depends_lib-append \ 
                    path:lib/pkgconfig/gobject-introspection-1.0.pc:gobject-introspection
    configure.args-replace \
                    -DGOBJECT_INTROSPECTION=OFF \
                    -DGOBJECT_INTROSPECTION=ON \
                    -DICAL_GLIB_VAPI=OFF \
                    -DICAL_GLIB_VAPI=ON
}

platform linux {
    build.env-append \
                    LD_LIBRARY_PATH=${build.dir}/lib
}
