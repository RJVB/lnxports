# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim: fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           cmake   1.1
PortGroup           github  1.1
PortGroup           LTO     1.0

github.setup        sahlberg libnfs b7118586654f4aee2bd722fdca0d07b3d08683f5
version             6.0.2.154
fetch.type          git
distname            ${name}-git
github.tarball_from archive

description         NFS client library

long_description    {*}${description}

categories          devel sysutils
license             {BSD LGPL-2.1+}
maintainers         {gmail.com:herby.gillot @herbygillot} \
                    openmaintainer

####################
if {${os.platform} ne "darwin"} {
    # libnfs is a system library so it seems wise to create a devport
    PortGroup devport 1.0

    create_devport port:${name} auto

    if {${subport} eq "${name}-dev"} {
        # we don't care about anything that follows,
        # return here to avoid having to add more subport checks.
        return
    }
}
####################

depends_lib-append  port:gnutls

configure.args-append \
                    -DBUILD_SHARED_LIBS=ON \
                    -DENABLE_UTILS=ON \
                    -DENABLE_MULTITHREADING=ON \
                    -DENABLE_TESTS=ON

