PortSystem          1.0

set LTO.fat_LTO_Objects yes
PortGroup           LTO 1.0
PortGroup           makefile 1.0
compwrap.add_compiler_flags yes
PortGroup           save_configure_cmd 1.0

description         The Linux-native asynchronous I/O library - experimental!
long_description    EXPERIMENTAL!\n\
                    The Linux-native asynchronous I/O facility ('async I/O', or 'aio') \
                    has a richer API and capability set than the simple POSIX async I/O \
                    facility. This library, libaio, provides the Linux-native API for \
                    async I/O. The POSIX async I/O facility requires this library in order \
                    to provide kernel-accelerated async I/O capabilities, as do applications \
                    which require the Linux-native async I/O API.\n\
                    This port is based on the latest Ubuntu package.
license             LGPL-2.1
maintainers         gmail.com:rjvbertin openmaintainer

name                libaio
set urevision       8
set uversion        0.3.113
version             ${uversion}.${urevision}
platforms           linux
master_sites        https://launchpad.net/ubuntu/+archive/primary/+sourcefiles/${name}/${uversion}-${urevision}
distname            ${name}_${uversion}
extract.suffix      .orig.tar.gz
worksrcdir          ${name}-${uversion}

checksums           rmd160  042622efcb6bc5127a93b6a9ef84f0b4fae80603 \
                    sha256  2c44d1c5fd0d43752287c9ae1eb9c023f04ef848ea8d4aafa46e9aedb678200b
#                    size    49980

####################
    # libaio is a system library so it seems wise to create a devport
    # so that we can be a pure runtime upgrade for non-MacPorts and they
    # do not inadvertently pull us in during building.
    PortGroup devport 1.0

    create_devport port:${name} auto

    if {${subport} eq "${name}-dev"} {
        # we don't care about anything that follows,
        # return here to avoid having to add more subport checks.
        return
    }
####################

